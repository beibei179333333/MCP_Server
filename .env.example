# 在 https://my.telegram.org/apps 申请 API 凭证
TG_API_ID=1234567
TG_API_HASH=abcdef0123456789abcdef0123456789
# 你的 Telegram 手机号(国际格式),首次登录用
TG_PHONE=+8613800000000
# session 文件名(无需修改)
TG_SESSION=clone_session

# 统一改写的 title (含 emoji)
NEW_TITLE=会员表情🔥 @emojipd
# 统一的 short_name 前缀,会拼接 _NNN
SHORT_PREFIX=emojipd
# 起始序号
START_INDEX=1

# fStikBot 用户名
BOT_USERNAME=fStikBot
# 每步之间最小等待秒数(防 flood)
STEP_DELAY=3
# 每个包完成后的休息秒数
PACK_DELAY=8
