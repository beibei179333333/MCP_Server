# ============================================
# Telegram 多功能机器人 配置示例
# 复制为 .env 并填入真实参数
# ============================================

# Bot Token：从 @BotFather 获取
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram API 凭据（搬运频道/群组消息需要 user-bot）
# https://my.telegram.org/apps 申请
TG_API_ID=1234567
TG_API_HASH=abcdef1234567890abcdef1234567890

# user-bot 登录用手机号（带国际区号）
TG_PHONE=+8613800000000

# 管理员 ID（多个用逗号分隔），可在 @userinfobot 查询
ADMIN_IDS=123456789,987654321

# 数据库文件路径
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# 默认时区
TIMEZONE=Asia/Shanghai

# 群发节流：每条消息间隔毫秒
BROADCAST_INTERVAL_MS=80

# 日志级别
LOG_LEVEL=INFO
