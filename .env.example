# ============================================================
# 方案 A(推荐):Bot API 直接克隆 —— clone_via_bot.py
# ============================================================
# @Biaoqing111bot 的 token(从 @BotFather 获取)
TG_BOT_TOKEN=8764496883:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 新包归属的用户 ID(必须是已经给该 bot 发过消息的人)。
# 留空则脚本自动从 getUpdates 取最近一个给 bot 发消息的人。
# 想手动指定就填你的数字 user_id(可问 @userinfobot 获取)。
BOT_OWNER_ID=

# 统一改写的 title(含 emoji)
NEW_TITLE=会员表情🔥 @emojipd
# 统一的 short_name 前缀,最终链接为 <前缀>_NNN_by_<bot用户名>
SHORT_PREFIX=emojipd
# 起始序号
START_INDEX=1

# 复用源贴纸的 file_id(快,不下载);失败会自动回退到下载再上传
REUSE_FILE_ID=1
# 每个包之间休息秒数,防限速
PACK_DELAY=3
# 只处理前 N 个包做测试(0 = 全部)
TEST_LIMIT=0


# ============================================================
# 方案 B(旧):Telethon 用户客户端 —— clone_packs.py
# ============================================================
# 在 https://my.telegram.org/apps 申请
TG_API_ID=1234567
TG_API_HASH=abcdef0123456789abcdef0123456789
TG_PHONE=+8613800000000
TG_SESSION=clone_session
BOT_USERNAME=fStikBot
STEP_DELAY=3
