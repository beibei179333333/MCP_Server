# ============================================================
# Telegram 多功能机器人 - 配置示例
# 复制为 .env 并填入真实值；带 [可选] 的可不填使用默认值
# ============================================================

# -------- Bot 核心 --------
# 从 @BotFather 获取
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 管理员 ID（多个用逗号分隔）；@userinfobot 可查
ADMIN_IDS=123456789,987654321

# -------- User-bot（搬运频道/群组消息需要） --------
# https://my.telegram.org/apps 申请
TG_API_ID=1234567
TG_API_HASH=abcdef1234567890abcdef1234567890
# user-bot 登录手机号（带国际区号）
TG_PHONE=+8613800000000
# [可选] 二步验证密码（如果开启了 2FA）
TG_PASSWORD=

# -------- 数据库 --------
# 默认 SQLite；切换到 Postgres 例：
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost/botdb
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# -------- 调度 / 时区 --------
TIMEZONE=Asia/Shanghai

# -------- 群发 --------
BROADCAST_INTERVAL_MS=80      # 每条消息间隔毫秒（防 FloodWait）
BROADCAST_BATCH=30            # 每批进度刷新

# -------- 群组管理 --------
ENABLE_CAPTCHA=true           # 新成员入群验证（按钮 / 算术）
CAPTCHA_TIMEOUT=120           # 验证超时秒，超时踢出
ENABLE_ANTI_SPAM=true         # 反链接 / 反 @ / 反炸群

# -------- 订阅 / 付费（可选） --------
# Telegram Stars / TON / 第三方支付链接（手动开通）
SUBSCRIPTION_ENABLED=true
DEFAULT_TRIAL_DAYS=7

# -------- Web 管理面板 --------
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_SECRET=change-me-to-random-32-chars-string
# 留空则用 ADMIN_IDS[0] 作为用户名 + WEB_SECRET 哈希作为密码
WEB_USERNAME=admin
WEB_PASSWORD=

# -------- 多语言 --------
DEFAULT_LANG=zh

# -------- 日志 --------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14
